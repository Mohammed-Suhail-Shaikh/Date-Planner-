# ─── Required for production (Vercel) ─────────────────────────────────────────

# Password for /admin — change this!
ADMIN_PASSWORD=your-secret-password

# Turso database (see docs/TURSO_SETUP.md)
# Local dev: use file:./local.db  OR  your Turso libsql:// URL
TURSO_DATABASE_URL=libsql://date-planner-mohammed-suhail-shaikh.aws-us-east-1.turso.io
# Required when using Turso cloud URL — create in Turso dashboard → Tokens
TURSO_AUTH_TOKEN=

# ─── Optional ─────────────────────────────────────────────────────────────────

# Public app URL for invite links — set this for the shortest, cleanest links.
# Use your Vercel production domain (e.g. date-planner.vercel.app) or a custom domain.
# Avoids team-scoped URLs like *-username-projects.vercel.app in copied links.
# NEXT_PUBLIC_APP_URL=https://date-planner.vercel.app
#
# If unset, the app uses Vercel's VERCEL_PROJECT_PRODUCTION_URL automatically on deploy.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Calendar invites (see docs/GOOGLE_SETUP.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
